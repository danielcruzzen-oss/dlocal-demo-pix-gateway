{
  "service": "pagos-uy-service",
  "region": "uy-montevideo-1",
  "environment": "production",
  "red_bancaria_uy": {
    "endpoint": "https://red-bancaria.internal.dlocal/api/v3",
    "partner_bank": "brou",
    "timeout_ms": 30000,
    "retry_policy": {
      "max_attempts": 3,
      "backoff_ms": 500,
      "jitter": true
    }
  },
  "circuit_breaker": {
    "failure_threshold": 0.5,
    "window_seconds": 60,
    "half_open_after_seconds": 30
  },
  "rate_limits": {
    "requests_per_second": 500,
    "burst": 100
  },
  "observability": {
    "metrics_endpoint": "http://prometheus.pagos-uy.svc:9090",
    "tracing_sample_rate": 0.1
  }
}
